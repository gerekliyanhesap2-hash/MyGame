# See: man pkg-config
prefix=/home/user/hostcwd/.buildozer/android/platform/build-arm64-v8a/build/other_builds/hostpython3/desktop/hostpython3/native-build/root/usr/local
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: Python
Description: Embed Python into an application
Requires:
Version: 3.14
Libs.private: -lpthread -ldl  -lutil
Libs: -L${libdir} -lpython3.14
Cflags: -I${includedir}/python3.14
